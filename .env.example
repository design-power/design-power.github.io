VITE_YANDEX_FORMS_SURVEY_ID=
VITE_YANDEX_FORMS_NAME_SLUG=name
VITE_YANDEX_FORMS_CONFIRMATION_SLUG=confirmation
# Optional for answers API (if required by account/org policy)
VITE_YANDEX_FORMS_ORG_ID=
VITE_YANDEX_FORMS_CLOUD_ORG_ID=
# Optional: if form uses personal links, set key from that URL
VITE_YANDEX_FORMS_KEY=
# Local-only fallback; do NOT use in production (it becomes public in frontend bundle)
VITE_YANDEX_FORMS_OAUTH_TOKEN=
# Leave empty for local dev (Vite proxy). For production set your Worker URL, e.g. https://wedding-yandex-forms-proxy.your-subdomain.workers.dev
VITE_YANDEX_FORMS_PROXY_URL=
